# คัดลอกเป็น .env แล้วแก้ค่า (ไม่ commit .env)

PORT=4000

# PostgreSQL — connection string (รวม user/password/host/port/database)
# พอร์ตต้องตรงกับที่เซิร์ฟเวอร์ฟังจริง (ค่าเริ่มต้น PG คือ 5432; ถ้า 5432 ถูก instance อื่นใช้แล้ว ให้ใช้พอร์ตที่ว่าง เช่น 5433)
# ตัวอย่าง: postgresql://pm_app:secret@127.0.0.1:5432/pm_dev
# ตัวอย่างเมื่อ PG 18 ฟังที่ 5433: postgresql://postgres:secret@127.0.0.1:5433/pm_dev
DATABASE_URL=postgresql://pm_app:CHANGE_ME@127.0.0.1:5432/pm_dev

# CORS: origin ของ Vite dev (ถ้าเรียก API ตรง URL ไม่ผ่าน proxy)
CORS_ORIGIN=http://localhost:5173

# ลงชื่อ JWT session (อย่างน้อย 16 ตัวอักษร)
SESSION_SECRET=change-me-to-a-long-random-secret

# Telegram Bot (Phase D — ผูกบัญชี + แจ้งเตือนจ่ายงาน)
# สร้าง Bot ที่ @BotFather แล้วใส่ token; production ต้องตั้ง webhook ด้วย secret เดียวกัน
TELEGRAM_BOT_TOKEN=
# ไม่บังคับ — ถ้าว่าง backend เรียก getMe เอา username
TELEGRAM_BOT_USERNAME=
# secret สำหรับ header X-Telegram-Bot-Api-Secret-Token บน webhook
TELEGRAM_WEBHOOK_SECRET=
# เปิด/ปิดการส่งข้อความ (false = ไม่ส่ง แต่ยังรับ webhook ผูกบัญชีได้)
TELEGRAM_NOTIFY_ENABLED=true
# URL สาธารณะของ API (ใช้สร้าง deep link / อ้างอิงในเอกสาร) — dev ผ่าน Vite proxy ไป :4000
APP_PUBLIC_URL=http://localhost:4000

# P5.1 dev UAT (mock chat IDs — ไม่ส่ง DM จริง)
# TELEGRAM_TEST_PLANNER_CHAT_ID=-100900001

# P5.2 backup — path ถ้า pg_dump ไม่อยู่ใน PATH (Windows ตัวอย่าง)
# PG_DUMP_PATH=C:/Program Files/PostgreSQL/18/bin/pg_dump.exe

# Portal hub — ปิด API / handoff โดยไม่ลบ frontend route (ค่าเริ่มต้น: เปิด)
# PORTAL_ENABLED=false
# MODULE_HANDOFF_ENABLED=false
# MODULE_HANDOFF_TTL_SEC=60
# MODULE_HANDOFF_RATE_PER_MIN=10
# MODULE_HANDOFF_ALLOWED_ORIGINS=https://store.example.com,https://repair.example.com
# MODULE_HANDOFF_CLIENTS=store:CHANGE_ME_store_secret,repair:CHANGE_ME_repair_secret
