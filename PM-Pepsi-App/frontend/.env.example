# Base URL ของ backend (ไม่มี trailing slash)
# ว่าง = เรียก same-origin path `/api/...` — Vite proxy ไป `http://127.0.0.1:4000` (ดู PM-Pepsi-App/backend + vite.config.ts)
# ตัวอย่างถ้าไม่ใช้ proxy: http://localhost:4000
VITE_API_URL=

# ต้องรัน backend ก่อน frontend: `cd PM-Pepsi-App/backend && npm run dev`
# ต้องมี migration 008 (tbmenu) + seed 009 (ADMIN01) ใน schema `app`

# Portal hub หลัง login (false = post-login แบบเดิม)
# VITE_PORTAL_ENABLED=false

# ข้าม portal เมื่อมีสิทธิ์ module เดียว (ช่าง W → /plan-calendar โดยตรง)
# VITE_PORTAL_AUTO_SKIP=true
