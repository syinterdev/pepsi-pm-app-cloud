# Copy to e2e/.env then: npm run test:e2e
# Admin workcenter (UserST=A) — หรือใช้ dev seed ด้านล่าง
E2E_ADMIN_USER=ADMIN01
E2E_ADMIN_PASSWORD=admin

# ทางเลือก: ใช้บัญชีจาก database/seeds/009_dev_auth_seed.sql โดยไม่ต้องตั้ง user/password
E2E_USE_DEV_SEED=1

PLAYWRIGHT_BASE_URL=http://localhost:5173
PLAYWRIGHT_API_URL=http://127.0.0.1:4000
