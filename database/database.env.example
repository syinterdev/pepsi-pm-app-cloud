# ตัวอย่างการตั้งค่าเชื่อม PostgreSQL (คัดลอกเป็น .env ภายนอก repo หรือใช้กับ psql / backend)
# ไม่ commit ค่าจริง

# DATABASE_URL=postgresql://pm_app:CHANGE_ME@127.0.0.1:5432/pm_dev
# ถ้า 5432 ถูก PostgreSQL ตัวอื่นใช้แล้ว ให้ใส่พอร์ตที่ instance แอป PM ฟัง เช่น 5433
# DATABASE_URL=postgresql://postgres:CHANGE_ME@127.0.0.1:5433/pm_dev
# PGHOST=127.0.0.1
# PGPORT=5432
# PGPORT=5433
# PGUSER=pm_app
# PGDATABASE=pm_dev
# PGPASSWORD=CHANGE_ME
